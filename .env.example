# Use either Vercel KV-style variables:
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Or Upstash Redis variables:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional: require a token for browser write/reset requests.
# BOARD_WRITE_TOKEN=

# Optional: change the Redis key used for the board state.
BOARD_KEY=amos-board:state
